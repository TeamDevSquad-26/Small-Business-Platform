rules_version = '2';

/**
 * Firebase Storage — shop media uploaded by authenticated owners.
 * Path: shops/{userId}/{fileName}
 */
service firebase.storage {
  match /b/{bucket}/o {
    match /shops/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
